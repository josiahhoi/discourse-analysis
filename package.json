{
    "name": "discourse-analysis",
    "version": "2.3.1",
    "description": "Discourse Analysis — diagram the logical structure of Scripture",
    "main": "main.js",
    "scripts": {
      "start": "electron .",
      "build": "electron-builder --mac --arm64 && electron-builder --win --x64",
      "build:mac": "electron-builder --mac --arm64",
      "build:win": "electron-builder --win --x64",
      "build:all": "npm run build"
    },
    "author": "",
    "license": "MIT",
    "devDependencies": {
      "electron": "^28.0.0",
      "electron-builder": "^24.9.1"
    },
    "build": {
      "appId": "com.discourseanalysis.app",
      "productName": "Discourse Analysis",
      "files": [
        "index.html",
        "styles.css",
        "app.js",
        "main.js"
      ],
      "directories": {
        "output": "dist"
      },
      "mac": {
        "category": "public.app-category.education",
        "target": [
          "zip"
        ],
        "icon": "build/icon.png"
      },
      "win": {
        "target": [
          "portable"
        ],
        "icon": "build/icon.png"
      },
      "portable": {
        "artifactName": "${productName} ${version} ${arch} Portable.${ext}"
      }
    }
  }